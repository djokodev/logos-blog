# Django Settings
SECRET_KEY=change-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=logos.djokodev.com
SITE_URL=https://logos.djokodev.com
WAGTAILADMIN_BASE_URL=https://logos.djokodev.com
SECURE_SSL_REDIRECT=True
UPLOAD_MAX_MB=25
READING_WORDS_PER_MINUTE=400

# Backup & Restore (VPS + R2)
BACKUP_BASE_DIR=/root/backups/logos-backend
BACKUP_RETENTION_WEEKS=12
BACKUP_LOG_FILE=/var/log/logos-backup.log
BACKUP_LOCK_FILE=/var/lock/logos-backup.lock
DB_CONTAINER_SERVICE=db
MEDIA_VOLUME_NAME=logos_media_volume

# Cloudflare R2 (S3 API)
R2_BUCKET_NAME=logos-backups
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PREFIX=prod/weekly
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me

# Database Settings (PostgreSQL in production, SQLite in local development if desired)
POSTGRES_DB=logos_db
POSTGRES_USER=logos_user
POSTGRES_PASSWORD=change-me-strong-db-password
DB_NAME=logos_db
DB_USER=logos_user
DB_PASSWORD=change-me-strong-db-password
DB_HOST=db
DB_PORT=5432
